#:kivy 1.0

<MyLayout>:
    FloatLayout:
        Button:
            id: previous_btn
            text: "PREVIOUS"
            size_hint: 0.5, 0.2
            pos_hint: {'center_x': 0.25, 'center_y':0.1}
        Button:
            id: forward_btn
            text: "NEXT"
            size_hint: 0.5, 0.2
            pos_hint: {'center_x': 0.75, "center_y": 0.1}
        